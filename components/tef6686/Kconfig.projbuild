menu "TEF6686 Configuration"

config TEF_I2C_SDA_PIN
    int "I2C SDA GPIO"
    default 8

config TEF_I2C_SCL_PIN
    int "I2C SCL GPIO"
    default 9

config TEF_I2C_FREQ_HZ
    int "I2C frequency (Hz)"
    default 400000

config TEF_I2C_PORT
    int "I2C port number"
    default 0

config TEF_CHIP_VERSION
    int "Chip version (102 or 205)"
    default 205
    help
        TEF6686 firmware patch version: 102 for V102/p224, 205 for V205/p512.

config TEF_XTAL_TYPE
    int "Crystal type"
    default 0
    help
        0=4MHz, 1=9.216MHz, 2=12MHz, 3=55MHz.

endmenu
